# =============================================================================
# APLICACION - apirestequipment
# =============================================================================
# Reemplaza los placeholders PLACEHOLDER_* antes de levantar la app

# Cadena de conexion a PostgreSQL (contenedor pgEquip)
DATABASE_URL=postgresql://adminEq:PLACEHOLDER_PG@localhost:5434/equipment

# Secreto para firmar tokens JWT (usa openssl rand -base64 32 para generarlo)
JWT_SECRET=PLACEHOLDER_JWT
JWT_EXPIRES_IN=7d

# Google OAuth (opcional, dejar vacio si no se usa)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=PLACEHOLDER_GOOGLE
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Servidor
PORT=3000
NODE_ENV=development

# =============================================================================
# POSTGRESQL - CONTENEDOR DEDICADO (pgEquip)
# =============================================================================
POSTGRES_CONTAINER=pgEquip
POSTGRES_USER=adminEq
POSTGRES_PASSWORD=PLACEHOLDER_PG
POSTGRES_DB=equipment
POSTGRES_PORT=5434

# =============================================================================
# MINIO - OBJECT STORAGE (S3-compatible)
# =============================================================================
# Credenciales root (administrativas: crear/gestionar buckets y usuarios)
MINIO_ROOT_USER=PLACEHOLDER_MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=PLACEHOLDER_MINIO_ROOT_PASSWORD
MINIO_CONTAINER=equip-minio

# Credenciales de aplicacion (acceso de la app al bucket - NO usar root en runtime)
MINIO_ACCESS_KEY=PLACEHOLDER_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=PLACEHOLDER_MINIO_SECRET_KEY

# Conexion desde la app (nombre del servicio en la red Docker)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false

# Bucket por defecto de la aplicacion
MINIO_BUCKET=PLACEHOLDER_MINIO_BUCKET

# =============================================================================
# PGADMIN - PostgreSQL Web UI (dev only)
# =============================================================================
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=PLACEHOLDER_PGADMIN
